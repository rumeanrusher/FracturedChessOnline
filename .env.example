# Copy this to .env for local development.
# On Render, set these as Environment Variables in the dashboard instead —
# never commit a real .env file.

# Postgres connection string. Render injects this automatically if you
# link a Render Postgres database to this web service (as DATABASE_URL).
DATABASE_URL=postgresql://user:password@localhost:5432/fractured_chess

# Secret used to sign JWT auth tokens. Generate a long random string for production.
JWT_SECRET=change-this-to-a-long-random-string

# Port the server listens on. Render sets this automatically — don't hardcode it.
PORT=3001

# Comma-separated list of allowed origins for CORS (your frontend URLs).
# Example: https://yourapp.netlify.app,https://yourusername.github.io
CORS_ORIGIN=*
